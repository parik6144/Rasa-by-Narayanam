# Database
DATABASE_URL="mysql://root:@localhost:3306/rasa_platform"

# Session
SESSION_SECRET="change-me-to-a-long-random-string"
COOKIE_SECURE=false

# Stripe (optional — without these, UPI QR path still works)
# Local: STRIPE_DEMO_MODE=true shows a working "Pay with card (demo)" button
# Live: set STRIPE_SECRET_KEY=sk_live_... or sk_test_... and turn demo off
STRIPE_DEMO_MODE=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
